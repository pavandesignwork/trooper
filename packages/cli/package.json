{
  "name": "usetrooper",
  "version": "0.1.0",
  "description": "Autonomous engineering agent — ingest feedback, write code, open PRs. BYOK.",
  "keywords": ["ai", "agent", "autonomous", "engineering", "byok", "github", "code-review"],
  "license": "MIT",
  "type": "module",
  "bin": {
    "trooper": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node --input-type=module -e \"import{chmodSync}from'fs';chmodSync('dist/index.js','755')\"",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@trooper/db": "workspace:*",
    "@trooper/core": "workspace:*",
    "inquirer": "^9.3.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.7",
    "tsx": "^4.15.0"
  }
}
