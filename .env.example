# AI model (BYOK — bring your own key)
TROOPER_MODEL_PROVIDER=claude        # claude | openai | gemini | groq | ollama
TROOPER_MODEL_NAME=claude-sonnet-4-6
TROOPER_API_KEY=sk-ant-...           # not needed for ollama

# GitHub
TROOPER_GITHUB_TOKEN=ghp_...
TROOPER_REPO_OWNER=your-org
TROOPER_REPO_NAME=your-repo

# Database (SQLite by default — no setup needed)
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./trooper.db

# For PostgreSQL (optional, for production teams)
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://user:pass@localhost:5432/trooper

# Server
PORT=3000
