{
  "name": "trooper",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous engineering agent — ingest feedback, write code, open PRs. BYOK.",
  "repository": {
    "type": "git",
    "url": "https://github.com/pavandesignwork/trooper"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint \"packages/*/src/**/*.ts\" --max-warnings 0",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "db:generate": "pnpm --filter @trooper/db generate",
    "db:migrate": "pnpm --filter @trooper/db migrate"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
